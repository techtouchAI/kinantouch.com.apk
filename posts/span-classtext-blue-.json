-900 flex justify-center py-4\">\n  <div class=\"relative w-full max-w-[320px] mx-auto pb-[177.78%]\"> \n    <iframe \n      class=\"absolute top-0 left-0 w-full h-full rounded-lg shadow-2xl\"\n      src=\"https://www.youtube.com/embed/kYe7TH1SsOw?rel=0&modestbranding=1\"\n      title=\"YouTube video\"\n      frameborder=\"0\"\n      allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\"\n      allowfullscreen>\n    </iframe>\n  </div>\n  \n</section>\n\n\n\n<section class=\"bg-blue-50 dark:bg-slate-800/50 border border-blue-100 dark:border-slate-700 rounded-2xl p-6 my-6 shadow-sm\">\n  <div class=\"flex items-center gap-3 mb-5\">\n    <span class=\"bg-blue-600 text-white w-10 h-10 flex items-center justify-center rounded-xl shadow-md text-lg\">\n        <svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4\"></path></svg>\n    </span>\n    <h3 class=\"font-bold text-xl text-blue-800 dark:text-blue-300\">الرابط بالاسفل نهاية المنشور</h3>\n  </div>\n\n  \n  <div class=\"bg-yellow-100 dark:bg-yellow-900/30 text-yellow-800 dark:text-yellow-200 p-4 rounded-xl text-sm mb-5 border-r-4 border-yellow-400 font-bold flex items-center gap-2\">\n    <svg class=\"w-5 h-5 shrink-0\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\" xmlns=\"http://www.w3.org/2000/svg\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z\"></path></svg>\n    <span>يرجى اتباع الخطوات بدقة لضمان النجاح.</span>\n  </div>\n\n  <ul class=\"list-decimal list-inside space-y-4 marker:text-blue-600 dark:marker:text-blue-400 marker:font-bold\">\n    <li class=\"pl-2 leading-relaxed text-gray-800 dark:text-gray-200\">تحتاج الى محفظة سوبر كي التفعيل بواسطة رقم موبايل او بطاقة ماستر</li>\n  </ul>\n</section>\n\n\n<section class=\"my-8\">\n  <h3 class=\"font-bold text-xl mb-3 text-blue-800 dark:text-blue-300\">افضل تطبيق لرمضان من Qi tv</h3>\n  <div class=\"text-gray-800 dark:text-gray-200 leading-relaxed text-base\">تطبيق Super Qi تعاقد ويا الرابعة على ضم المسلسلات الرمضانية العراقية الحصرية 2026 ومسلسلات تركية ومسلسلات الرابعة وقنوات الرابعة الترفيهية والرياضية وقنوات osn الترفيهية 🔥 واكتشف الباقي بنفسك... بداخل التطبيق اسمة QITV • فقط تحتاج الى محفظة سوبر كي بواسطة رقم موبايل او بطاقة ماستر.</div>\n</section>\n\n<section class=\"my-8\">\n  <h3 class=\"font-bold text-xl mb-3 text-blue-800 dark:text-blue-300\">مشاهدة ممتعة 🌹</h3>\n  \n</section>\n\n\n<section class=\"grid gap-4 sm:grid-cols-2 mt-10 pt-6 border-t border-gray-200 dark:border-gray-800\">\n  \n  <a href=\"https://play.google.com/store/apps/details?id=iq.qicard.qipay.prod\" target=\"_blank\" rel=\"noopener noreferrer\"\n     class=\"flex items-center justify-center gap-4 bg-gray-900 text-white dark:bg-gray-800 py-3 px-6 rounded-2xl shadow-lg hover:shadow-xl hover:-translate-y-1 transition-all duration-300 border border-gray-700 dark:border-gray-600 w-full group\">\n    <svg class=\"w-8 h-8 drop-shadow-md shrink-0 group-hover:scale-110 transition-transform\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M3.141 2.502c-.114.12-.188.293-.188.514v18.064c0 .22.074.394.188.514l.02.017 10.158-10.159v-.036L3.16 2.485l-.02.017z\" fill=\"#00A2E8\"/><path d=\"M17.373 13.578l-4.053-4.053v.036l4.053-4.053.023.013 4.808 2.735c1.373.78 1.373 2.057 0 2.838l-4.808 2.735-.023.014z\" fill=\"#FFC90E\"/><path d=\"M13.32 9.525l-10.16-10.16C2.607-.942 1.631-.419 1.631.547v.035l11.689 8.943z\" fill=\"#ED1C24\"/><path d=\"M13.32 14.571L1.631 23.514v.036c0 .967.976 1.488 1.529 1.181l10.16-10.16z\" fill=\"#22